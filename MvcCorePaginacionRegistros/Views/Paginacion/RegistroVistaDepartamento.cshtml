@model VistaDepartamento
<h1>Paginación individual</h1>

<h3 style="color:blue">Registro @Model.Posicion de @ViewData["ULTIMO"]</h3>

<div>
    <ul class="list-group-horizontal">
        <li class="list-group-item">
            <a asp-controller="Paginacion" asp-action="DetailsDept" asp-route-posicion="1">Primero</a>
        </li>
        <li class="list-group-item">
            <a asp-controller="Paginacion" asp-action="DetailsDept" asp-route-posicion="@ViewData["ANTERIOR"]">Anterior</a>
        </li>
        <li class="list-group-item">
            <a asp-controller="Paginacion" asp-action="DetailsDept" asp-route-posicion="@ViewData["SIGUIENTE"]">Siguiente</a>
        </li>
        <li class="list-group-item">
            <a asp-controller="Paginacion" asp-action="DetailsDept" asp-route-posicion="@ViewData["ULTIMO"]">Último</a>
        </li>
    </ul>
</div>

<ul class="list-group">
    <li class="list-group-item"><b>Número:</b> @Model.IdDepartamento</li>
    <li class="list-group-item"><b>Nombre:</b> @Model.Nombre</li>
    <li class="list-group-item"><b>Localidad:</b> @Model.Localidad</li>
</ul>

