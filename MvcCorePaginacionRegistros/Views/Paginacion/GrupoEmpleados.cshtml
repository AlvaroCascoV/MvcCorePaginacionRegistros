@model List<Empleado>

<h1 style="color:yellowgreen">Paginacion en grupo EMP</h1>

<hr />
@{
    int numRegistros = (int)ViewData["REGISTROS"];
    int numPagina = 1;
}

@for (int i = 1; i <= numRegistros; i += 3) 
{
    <a class='btn btn-primary' asp-action='GrupoEmpleados' asp-controller='Paginacion' asp-route-posicion='@i'>Página @numPagina </a>
    numPagina += 1;
}
<table class="table table-warning">
    <thead>
        <tr>
            <th>Id</th>
            <th>Apellido</th>
            <th>Oficio</th>
            <th>Salario</th>
            <th>DeptNo</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Empleado emp in Model)
        {
            <tr>
                <td>@emp.IdEmpleado</td>
                <td>@emp.Apellido</td>
                <td>@emp.Oficio</td>
                <td>@emp.Salario</td>
                <td>@emp.IdDepartamento</td>
            </tr>
        }
    </tbody>
</table>