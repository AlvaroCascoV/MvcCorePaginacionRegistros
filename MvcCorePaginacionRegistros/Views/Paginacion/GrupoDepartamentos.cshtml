@model List<Departamento>

<h1 style="color:blue">Paginacion en grupo</h1>

<hr />
@{
    //hacemos aqui el bucle para poder personalizar los links
    int numRegistros = (int)ViewData["NREGISTROS"];
    int numPagina = 1;
}

@for (int i = 1; i <= numRegistros; i += 2) //el 2 es el numero de registros que se muestran en cada pagina
{
    <a class='btn btn-primary' asp-action='GrupoDepartamentos' asp-controller='Paginacion' asp-route-posicion='@i'>Página @numPagina </a>
    numPagina += 1;
}
<table class="table table-warning">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Localidad</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Departamento dept in Model)
        {
            <tr>
                <td>@dept.IdDepartamento</td>
                <td>@dept.Nombre</td>
                <td>@dept.Localidad</td>
            </tr>
        }
    </tbody>
</table>